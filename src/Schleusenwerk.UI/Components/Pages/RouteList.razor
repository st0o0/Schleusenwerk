@page "/routes"
@using Schleusenwerk.Contracts
@inject IRouteClient RouteClient
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@rendermode @(new InteractiveServerRenderMode())

<PageTitle>Routes — Schleusenwerk</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h5">Routes</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               Href="/routes/new">New Route</MudButton>
</MudStack>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudTable Items="_routes" Hover="true" Dense="true">
        <HeaderContent>
            <MudTh>Domain</MudTh>
            <MudTh>Source</MudTh>
            <MudTh>HTTPS</MudTh>
            <MudTh>Upstreams</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudLink Href="@($"/routes/{context.Domain}")">@context.Domain</MudLink>
            </MudTd>
            <MudTd><SourceBadge Source="@context.Source" /></MudTd>
            <MudTd>
                @if (context.ForceHttps)
                {
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Success" Size="Size.Small" />
                }
            </MudTd>
            <MudTd>@context.Upstreams.Count</MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                               OnClick="@(() => DeleteAsync(context.Domain))" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private List<RouteSummary> _routes = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _routes = (await RouteClient.ListRoutesAsync()).ToList();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task DeleteAsync(string domain)
    {
        var result = await RouteClient.DeleteRouteAsync(domain);
        if (result.Success)
        {
            _routes.RemoveAll(r => r.Domain == domain);
            Snackbar.Add($"Route {domain} deleted", Severity.Success);
        }
        else
        {
            Snackbar.Add(result.ErrorMessage, Severity.Error);
        }
    }
}
